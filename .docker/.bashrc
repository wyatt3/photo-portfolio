export LS_OPTIONS='--color=auto';alias ls='ls $LS_OPTIONS';alias ll='ls $LS_OPTIONS -l';alias l='ls $LS_OPTIONS -lA';alias la='ls $LS_OPTIONS -A';alias composer='php /usr/local/bin/composer';alias phpunit='php vendor/bin/phpunit';alias coverage='php artisan test --coverage --parallel --coverage-html=storage/logs/coverage';alias phpunitcoverage='phpunit --coverage-html storage/logs/coverage';alias ..='cd ..';alias ...='cd ../..';alias stan='vendor/bin/phpstan analyse';
